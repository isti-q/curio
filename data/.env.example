# Copy to .env and fill in your key. Used by data/generate-facts.js.
OPENAI_API_KEY=your-api-key-here

# "append" (default) keeps existing content and continues after the last fact;
# "replace" overwrites everything from scratch (use for the first seed).
MODE=append

# First fact's date (YYYY-MM-DD). Leave unset to auto-continue / use today.
# START_DATE=2026-06-06

# How many facts/quotes to generate per run.
TOTAL=90
